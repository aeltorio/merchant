{
  "name": "merchant",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source commerce backend. Bring Stripe key, start selling.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:env": "bash -c 'cp ../../.env .dev.vars && wrangler dev'",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute DB --file=schema-d1.sql --local",
    "db:seed": "npx tsx scripts/seed.ts",
    "test": "vitest --config vitest.config.ts --run"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.0",
    "@hono/zod-openapi": "^0.18.3",
    "hono": "^4.12.5",
    "stripe": "^17.0.0",
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.70.0"
  }
}